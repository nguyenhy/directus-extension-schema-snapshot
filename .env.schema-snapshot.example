# Copy this file to .env and adjust as needed. All vars optional — defaults shown.
#
# NOTE: dotenv loads from process.cwd()/.env by default — NOT this package's
# own directory. If invoked via a wrapper that changes cwd (e.g. `npm run`),
# that can silently load the wrong .env. Pin the path explicitly with
# --env-file <path>, or SCHEMA_SNAPSHOT_ENV_FILE below (set as a real env
# var before invoking, not inside .env itself — chicken/egg).

# Explicit path to the .env file to load. Fallback for when --env-file CLI
# flag isn't available (e.g. set by a wrapper script). See note above.
# SCHEMA_SNAPSHOT_ENV_FILE=./snapshot/.env

# Default output directory for `normalize` when --out-dir is not passed.
SCHEMA_SNAPSHOT_OUT_DIR=.snapshot/normalized

# Default normalizer for `normalize`/`diff` when --schema-type is not passed.
# Must match a key registered in src/core/normalizers/index.js.
SCHEMA_SNAPSHOT_TYPE=directus

# Default subdir naming template for `normalize` when --subdir-format is not
# passed. Placeholders: {name} (input basename), {time} (YYYYMMDD-HHmmss).
# See docs/architecture.md#subdir-format for full rules and examples.
SCHEMA_SNAPSHOT_SUBDIR_FORMAT={time}_{name}

# Where the local GitStore cache lives (git-backed, disposable/rebuildable
# via `sync` — NOT the source of truth). Used by diff/add/list/show/get/
# remove/extract/sync/status. Keep this gitignored in the host repo.
SCHEMA_SNAPSHOT_STORE_DIR=.snapshot/repo

# Which Store implementation core/env.js's createEnv() constructs.
# Must match a case in core/env.js's createStore(). Only "git" exists today.
SCHEMA_SNAPSHOT_STORE_TYPE=git

# Which Parser core/env.js's createEnv() constructs. Must match a key
# registered in src/core/parsers/index.js. Only "json" exists today.
SCHEMA_SNAPSHOT_FILE_FORMAT=json

# Host-repo-tracked event log + content-addressed source dir — the sync-able
# source of truth (schema-snapshots/meta.json + source/<hash>.json). Meant
# to be committed by the project's own git, unlike SCHEMA_SNAPSHOT_STORE_DIR.
# Used by add/show/get/diff/extract/remove/sync/status.
# See docs/proposal-schema-snapshot-sync.md and docs/architecture.md
# "Schema-snapshots sync layer".
SCHEMA_SNAPSHOT_SNAPSHOTS_DIR=schema-snapshots
